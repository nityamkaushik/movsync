{
  "rules": {
    "movsync": {
      "rooms": {
        "$roomCode": {
          ".read": true,
          "createdAt": {
            ".write": "auth != null"
          },
          "started": {
            ".write": "auth != null"
          },
          "allowControls": {
            ".write": "auth != null"
          },
          "voiceActive": {
            ".write": "auth != null"
          },
          "sync": {
            ".write": true,
            ".validate": "newData.hasChildren(['command', 'position', 'timestamp', 'senderId'])"
          },
          "heartbeat": {
            ".write": true,
            ".validate": "newData.hasChildren(['position', 'isPlaying', 'timestamp'])"
          },
          "presence": {
            "$userId": {
              ".write": "auth != null || !data.exists()",
              ".read": true
            }
          },
          "chat": {
            "$messageId": {
              ".write": true
            }
          }
        }
      }
    }
  }
}
